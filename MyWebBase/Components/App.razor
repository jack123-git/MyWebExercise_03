<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <ResourcePreloader />
    <link href="https://fonts.googleapis.com/css2?family=Roboto:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="@Assets["_content/MudBlazor/MudBlazor.min.css"]" />
    <link rel="stylesheet" href="@Assets["MyWebBase.styles.css"]" />
    <ImportMap />
    <link rel="icon" type="image/ico" href="favicon.ico" />
    <HeadOutlet @rendermode="InteractiveServer" />
</head>

<body>
    <Routes @rendermode="InteractiveServer" />
    <ReconnectModal />
    <script src="@Assets["_framework/blazor.web.js"]"></script>
    <script src="@Assets["_content/MudBlazor/MudBlazor.min.js"]"></script>

    <script>
        window.timeOutDetector = {
            dotNetReference: null,
            timer: null,
            startTimer: function (dotNetRef, timeoutMs) {
                this.dotNetReference = dotNetRef;
                this.resetTimer(timeoutMs);

                // 監聽常見的操作事件
                const events = ['mousemove', 'keypress', 'mousedown', 'touchstart'];

                events.forEach(evt => {
                        window.addEventListener(evt, () => this.resetTimer(timeoutMs), true);
                    });
                },
                resetTimer: function (timeoutMs) {
                clearTimeout(this.timer);
                this.timer = setTimeout(() => {
                    // 觸發 Blazor 的強制登出方法
                    if (this.dotNetReference) {
                    this.dotNetReference.invokeMethodAsync('LogoutUserDueToInactivity');
                    }
                }, timeoutMs);
            }
        };
    </script>
</body>

</html>
